#1 Two Sum

# Given a list of integers find the 2 positions where the integers' sum equals the target

class Solution:
    def twoSum(self, nums: List[int], target: int) -> List[int]:

        # Array of nums, target -> return the positions where nums == target

        # Loops the length of List - 1
        for i in range(len(nums) - 1):
            # Goes from the adjacent position to the end
            for j in range(i+1, len(nums)):
                # If the sum == target then return
                if nums[i] + nums[j] == target:
                    return i, j





